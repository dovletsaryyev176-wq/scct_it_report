

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>"E-MAKSATNAMA" ulgamy</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="#">"E-MAKSATNAMA" ulgamy</a>
            <div class="navbar-nav ms-auto">
                
                {% if session.get('user_id') %}
                    <span class="nav-link text-warning fw-bold">{{ session.role | upper }}</span>
                    <a class="nav-link" href="{{ url_for('auth.logout') }}">Ulgamdan çykmak ({{ session.username }})</a>
                {% else %}
                    <a class="nav-link" href="{{ url_for('auth.login') }}">Ulgama girmek</a>
                {% endif %}


            </div>
        </div>
    </nav>

    <div class="container">
        {% with messages = get_flashed_messages(with_categories=true) %}
          {% if messages %}
            {% for category, message in messages %}
              <div class="alert alert-{{ category }} alert-dismissible fade show shadow-sm">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            {% endfor %}
          {% endif %}
        {% endwith %}

        {% block content %}{% endblock %}
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>